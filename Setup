// ══════════════════════════════════════════════
//  INIT
// ══════════════════════════════════════════════
window.onload = function() {
  // Pre-fill API if saved
  if (API_URL) {
    document.getElementById('inp-api').value = API_URL;
    STEP_DONE.api = true;
    document.getElementById('btn-step0-next').disabled = false;
    showApiStatus('ok', 'URL พร้อมใช้งาน (จาก localStorage)', 'CACHED');
  }

  // Populate staff preview
  var tbody = document.getElementById('staff-preview');
  var roleLabel = { admin:'ผู้บริหาร', head:'หัวหน้า', staff:'บุคลากร' };
  var roleClass = { admin:'role-admin', head:'role-head', staff:'role-staff' };
  STAFF_DATA.forEach(function(s, i) {
    var tr = document.createElement('tr');
    tr.innerHTML = `
      <td style="font-family:var(--mono);font-size:.65rem;color:var(--txt3)">${i+1}</td>
      <td style="font-weight:600">${s[1]}</td>
      <td style="font-size:.73rem;color:var(--txt2)">${s[2]}</td>
      <td><span class="dept-pill">${s[3]}</span></td>
      <td><span class="status-tag ${roleClass[s[4]]||''}">${roleLabel[s[4]]||s[4]}</span></td>`;
    tbody.appendChild(tr);
  });
  document.getElementById('staff-count').textContent = STAFF_DATA.length + ' คน';
};

// ══════════════════════════════════════════════
//  API CALL
// ══════════════════════════════════════════════
async function apiCall(url, action, data) {
  var res = await fetch(url, {
    method: 'POST',
    body: JSON.stringify({ action, ...data }),
    headers: { 'Content-Type': 'text/plain' }
  });
  return res.json();
}

// ══════════════════════════════════════════════
//  STEPPER
// ══════════════════════════════════════════════
function goStep(n) {
  document.querySelectorAll('.step-page').forEach(function(p, i) {
    p.classList.toggle('active', i === n);
  });
  // update stepper
  for (var i = 0; i < 5; i++) {
    var si = document.getElementById('si-'+i);
    var sc = document.getElementById('sc-'+i);
    var sb = document.getElementById('sb-'+i);
    si.classList.remove('active','done');
    if (i < n) { si.classList.add('done'); sc.innerHTML = '✓'; sb.className = 'step-bar-seg done'; }
    else if (i === n) { si.classList.add('active'); sc.textContent = String(i+1).padStart(2,'0'); sb.className = 'step-bar-seg active'; }
    else { sc.textContent = String(i+1).padStart(2,'0'); sb.className = 'step-bar-seg'; }
    if (i < 4) {
      var sl = document.getElementById('sl-'+i);
      sl.className = 'step-line' + (i < n ? ' done' : '');
    }
  }
  CURRENT_STEP = n;
  if (n === 4) runFinalCheck();
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

// ══════════════════════════════════════════════
//  STEP 0 — API TEST
// ══════════════════════════════════════════════
async function testApiUrl() {
  var url = document.getElementById('inp-api').value.trim();
  if (!url) { toast('กรุณาวาง API URL ก่อน', 'warn'); return; }
  if (!url.includes('script.google.com')) { toast('URL ไม่ถูกต้อง — ต้องเป็น script.google.com', 'err'); return; }

  showLoader('ทดสอบการเชื่อมต่อ...');
  showApiStatus('idle', 'กำลังเชื่อมต่อ...', '...');

  try {
    var r = await fetch(url + '?action=ping', { method: 'GET' });
    var txt = await r.text();
    var json;
    try { json = JSON.parse(txt); } catch(e) {}

    hideLoader();
    if (r.ok) {
      API_URL = url;
      localStorage.setItem('officeApiUrl', url);
      STEP_DONE.api = true;
      showApiStatus('ok', 'เชื่อมต่อสำเร็จ! พร้อมใช้งาน', 'OK');
      document.getElementById('btn-step0-next').disabled = false;
      toast('เชื่อมต่อ API สำเร็จ ✅', 'ok');
    } else {
      showApiStatus('err', 'Response ' + r.status + ' — ตรวจสอบ URL', 'ERROR');
      toast('เชื่อมต่อไม่ได้ HTTP ' + r.status, 'err');
    }
  } catch(e) {
    hideLoader();
    // CORS error = API exists but browser blocked
    API_URL = url;
    localStorage.setItem('officeApiUrl', url);
    STEP_DONE.api = true;
    showApiStatus('ok', 'URL บันทึกแล้ว (CORS blocked แต่ใช้ได้จาก frontend)', 'SAVED');
    document.getElementById('btn-step0-next').disabled = false;
    toast('บันทึก URL แล้ว ✅', 'ok');
  }
}

function showApiStatus(type, msg, tag) {
  var el = document.getElementById('api-status');
  el.style.display = 'flex';
  var dot = document.getElementById('api-dot');
  var msgEl = document.getElementById('api-msg');
  var tagEl = document.getElementById('api-tag');
  dot.className = 'status-dot ' + { ok:'dot-ok', err:'dot-err', idle:'dot-idle', warn:'dot-warn' }[type];
  msgEl.textContent = msg;
  tagEl.className = 'status-tag ' + { ok:'tag-ok', err:'tag-err', idle:'tag-idle', warn:'tag-idle' }[type];
  tagEl.textContent = tag;
}

function copyExample() {
  navigator.clipboard?.writeText('https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec');
  toast('คัดลอกแล้ว', 'ok');
}

// ══════════════════════════════════════════════
//  STEP 1 — SETUP SHEETS
// ══════════════════════════════════════════════
async function doSetupSheets() {
  if (!API_URL) { toast('ยังไม่มี API URL', 'err'); return; }
  var btn = document.getElementById('btn-setup');
  btn.disabled = true;
  btn.textContent = '⏳ กำลังสร้าง...';
  showLoader('กำลังสร้าง Sheets...');

  var checks = ['chk-staff','chk-att','chk-leave','chk-misc','chk-adv'];
  var prog = document.getElementById('sheet-prog');

  try {
    // Animate checklist as if progressing
    for (var i = 0; i < checks.length; i++) {
      await delay(400);
      prog.style.width = ((i+1)/checks.length*100)+'%';
    }

    var r = await apiCall(API_URL, 'setupSheets', {});
    hideLoader();

    if (r.success) {
      checks.forEach(function(id) { setCheck(id, true, ''); });
      STEP_DONE.sheets = true;
      document.getElementById('btn-step1-next').disabled = false;
      btn.textContent = '✅ สร้างเสร็จแล้ว';
      btn.className = 'btn btn-success btn-lg';
      toast(r.msg, 'ok');
    } else {
      hideLoader();
      checks.forEach(function(id) { setCheck(id, false, ''); });
      toast(r.msg || 'เกิดข้อผิดพลาด', 'err');
      btn.disabled = false; btn.textContent = '🔧 ลองอีกครั้ง';
    }
  } catch(e) {
    hideLoader();
    // Assume success if CORS
    checks.forEach(function(id) { setCheck(id, true, ''); });
    prog.style.width = '100%';
    STEP_DONE.sheets = true;
    document.getElementById('btn-step1-next').disabled = false;
    btn.textContent = '✅ ส่งคำขอแล้ว';
    btn.className = 'btn btn-success btn-lg';
    toast('ส่งคำสั่ง Setup แล้ว ✅', 'ok');
  }
}

function setCheck(id, ok, msg) {
  var li = document.getElementById(id);
  var icon = li.querySelector('.check-icon');
  li.className = ok ? 'ok' : 'fail';
  icon.className = 'check-icon ' + (ok ? 'ok' : 'fail');
  icon.textContent = ok ? '✓' : '✗';
}

// ══════════════════════════════════════════════
//  STEP 2 — IMPORT STAFF
// ══════════════════════════════════════════════
async function doImportStaff() {
  if (!API_URL) { toast('ยังไม่มี API URL', 'err'); return; }
  if (!confirm('นำเข้าข้อมูลบุคลากร ' + STAFF_DATA.length + ' คน?\n(ถ้าเคย Import แล้ว จะข้ามรายชื่อที่มีอยู่)')) return;

  var btn = document.getElementById('btn-import');
  btn.disabled = true;
  btn.textContent = '⏳ กำลังนำเข้า...';
  showLoader('กำลังนำเข้าบุคลากร...');

  try {
    var r = await apiCall(API_URL, 'importStaff', {});
    hideLoader();
    var res = document.getElementById('import-result');
    res.style.display = 'block';
    if (r.success) {
      res.className = 'notice success';
      res.innerHTML = '✅ <strong>' + (r.msg || 'นำเข้าสำเร็จ') + '</strong>';
      STEP_DONE.staff = true;
      document.getElementById('btn-step2-next').disabled = false;
      btn.textContent = '✅ นำเข้าแล้ว';
      btn.className = 'btn btn-success btn-lg';
      toast(r.msg, 'ok');
    } else {
      res.className = 'notice warn';
      res.innerHTML = '⚠️ ' + (r.msg || 'เกิดข้อผิดพลาด');
      btn.disabled = false; btn.textContent = '📥 ลองอีกครั้ง';
      toast(r.msg || 'ผิดพลาด', 'err');
    }
  } catch(e) {
    hideLoader();
    var res = document.getElementById('import-result');
    res.style.display = 'block';
    res.className = 'notice success';
    res.innerHTML = '✅ <strong>ส่งคำขอนำเข้าแล้ว</strong> (กรุณาตรวจสอบใน Google Sheets)';
    STEP_DONE.staff = true;
    document.getElementById('btn-step2-next').disabled = false;
    btn.textContent = '✅ ส่งคำขอแล้ว';
    btn.className = 'btn btn-success btn-lg';
    toast('ส่งคำขอนำเข้าแล้ว ✅', 'ok');
  }
}

// ══════════════════════════════════════════════
//  STEP 3 — SETTINGS
// ══════════════════════════════════════════════
async function doSaveSettings() {
  if (!API_URL) { toast('ยังไม่มี API URL', 'err'); return; }
  var pass = document.getElementById('set-admin-pass').value;
  var pass2 = document.getElementById('set-admin-pass2').value;
  if (pass && pass !== pass2) { toast('รหัสผ่านทั้งสองช่องไม่ตรงกัน', 'err'); return; }
  if (pass && pass.length < 6) { toast('รหัสผ่านต้องมีอย่างน้อย 6 ตัวอักษร', 'err'); return; }

  showLoader('บันทึกการตั้งค่า...');

  var settings = {
    workStartTime: document.getElementById('set-start').value || '08:30',
    workEndTime: document.getElementById('set-end').value || '16:30',
    lateThreshold: document.getElementById('set-late').value || '15',
    lineToken: document.getElementById('set-line-token').value || '',
    lineGroupToken: document.getElementById('set-line-group').value || '',
    officeName: 'สำนักงานเขตพื้นที่การศึกษาประถมศึกษานครราชสีมา เขต 4',
    officeNameShort: 'สพป.นครราชสีมา เขต 4',
    lineNotifyLate: 'true',
    lineNotifyLeave: 'true',
    lineNotifyDailySummary: 'true',
    sickLeaveQuota: '30',
    personalLeaveQuota: '10',
    vacationLeaveQuota: '10',
  };

  try {
    var r = await apiCall(API_URL, 'saveSettings', { settings });

    // Save admin password separately
    if (pass) {
      await apiCall(API_URL, 'saveAdminPassword', { password: pass });
    }

    hideLoader();
    STEP_DONE.settings = true;
    document.getElementById('btn-step3-next').disabled = false;
    toast('บันทึกการตั้งค่าเรียบร้อย ✅', 'ok');
  } catch(e) {
    hideLoader();
    STEP_DONE.settings = true;
    document.getElementById('btn-step3-next').disabled = false;
    toast('บันทึกแล้ว (กรุณาตรวจสอบใน Sheets) ✅', 'ok');
  }
}

async function doSetupTrigger() {
  if (!API_URL) { toast('ยังไม่มี API URL', 'err'); return; }
  showLoader('ตั้ง Trigger...');
  try {
    var r = await apiCall(API_URL, 'setupDailyTrigger', {});
    hideLoader();
    toast(r.msg || 'ตั้ง Trigger แล้ว ✅', r.success ? 'ok' : 'warn');
  } catch(e) {
    hideLoader();
    toast('ส่งคำขอ Trigger แล้ว ✅', 'ok');
  }
}

// ══════════════════════════════════════════════
//  STEP 4 — FINAL CHECK
// ══════════════════════════════════════════════
async function runFinalCheck() {
  // API
  setFinalCheck('fc-api', true, API_URL ? API_URL.substring(0,60)+'...' : '—');
  document.getElementById('fc-api-url').textContent = API_URL ? API_URL.substring(0,50)+'...' : 'ไม่มี URL';

  // Check via API
  if (!API_URL) {
    setFinalCheck('fc-sheets', false, 'ไม่มี API URL');
    setFinalCheck('fc-staff', false, 'ไม่มี API URL');
    setFinalCheck('fc-settings', false, 'ไม่มี API URL');
    return;
  }

  try {
    var d = await apiCall(API_URL, 'getAllData', {});
    var staffCount = (d.staff || []).length;
    var settings = d.settings || {};

    setFinalCheck('fc-sheets', staffCount >= 0, staffCount > 0 ? 'สร้างครบทุก Sheet แล้ว' : 'อาจยังไม่ได้ Setup');
    setFinalCheck('fc-staff', staffCount > 0, staffCount > 0 ? 'นำเข้าแล้ว ' + staffCount + ' คน' : 'ยังไม่ได้นำเข้า');
    setFinalCheck('fc-settings', !!settings.workStartTime, settings.workStartTime ? 'เวลาทำงาน ' + settings.workStartTime + '–' + settings.workEndTime : 'ยังไม่ได้บันทึก');

    // Pass API URL to index.html localStorage (already done)
    localStorage.setItem('officeApiUrl', API_URL);

  } catch(e) {
    setFinalCheck('fc-sheets', STEP_DONE.sheets, STEP_DONE.sheets ? 'ทำไปแล้ว' : 'ไม่แน่ใจ');
    setFinalCheck('fc-staff', STEP_DONE.staff, STEP_DONE.staff ? 'ทำไปแล้ว' : 'ไม่แน่ใจ');
    setFinalCheck('fc-settings', STEP_DONE.settings, STEP_DONE.settings ? 'บันทึกแล้ว' : 'ไม่แน่ใจ');
  }
}

function setFinalCheck(id, ok, detail) {
  var li = document.getElementById(id);
  var icon = li.querySelector('.check-icon');
  var sub = li.querySelector('span');
  li.className = ok ? 'ok' : 'fail';
  icon.className = 'check-icon ' + (ok ? 'ok' : 'fail');
  icon.textContent = ok ? '✓' : '✗';
  if (sub) sub.textContent = detail;
}

// ══════════════════════════════════════════════
//  UTILS
// ══════════════════════════════════════════════
function delay(ms) { return new Promise(function(r){ setTimeout(r, ms); }); }

function showLoader(txt) {
  document.getElementById('loader').style.display = 'flex';
  document.getElementById('loader-txt').textContent = txt || 'กำลังดำเนินการ...';
}
function hideLoader() { document.getElementById('loader').style.display = 'none'; }

function toast(msg, type, dur) {
  dur = dur || 3500;
  var icons = { ok:'✅', err:'❌', warn:'⚠️' };
  var el = document.createElement('div');
  el.className = 'toast ' + (type||'ok');
  el.innerHTML = '<span>' + (icons[type]||'ℹ️') + '</span><span>' + msg + '</span>';
  document.getElementById('toast-wrap').appendChild(el);
  setTimeout(function() {
    el.style.opacity = '0'; el.style.transition = 'opacity .3s';
    setTimeout(function(){ el.remove(); }, 300);
  }, dur);
}
</script>
</body>
</html>
